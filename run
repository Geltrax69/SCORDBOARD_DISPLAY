#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
#  Scoreboard Pro — launcher (macOS / Linux / Git Bash on Windows)
#  Usage:  ./run            → start everything (dev mode)
#          ./run --stop     → stop everything
#          ./run --prod     → production mode (docker compose full stack)
# ──────────────────────────────────────────────────────────────────────────────
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND="$ROOT/backend"
FRONTEND="$ROOT/frontend"

# ── Colors ────────────────────────────────────────────────────────────────────
BOLD=$'\033[1m'; RESET=$'\033[0m'
RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'; MAGENTA=$'\033[0;35m'; BLUE=$'\033[0;34m'

log()  { echo "${BOLD}${CYAN}[run]${RESET} $*"; }
ok()   { echo "${BOLD}${GREEN}[ ok]${RESET} $*"; }
warn() { echo "${BOLD}${YELLOW}[warn]${RESET} $*"; }
err()  { echo "${BOLD}${RED}[err]${RESET} $*" >&2; }
step() { echo ""; echo "${BOLD}${BLUE}── $* ──────────────────────────────────────────${RESET}"; }

# ── PIDs ──────────────────────────────────────────────────────────────────────
BACKEND_PID=""; FRONTEND_PID=""

cleanup() {
  echo ""
  log "Shutting down…"
  [[ -n "$BACKEND_PID" ]]  && kill -0 "$BACKEND_PID"  2>/dev/null && kill "$BACKEND_PID"  2>/dev/null && ok "Backend stopped"
  [[ -n "$FRONTEND_PID" ]] && kill -0 "$FRONTEND_PID" 2>/dev/null && kill "$FRONTEND_PID" 2>/dev/null && ok "Frontend stopped"
  log "All processes stopped. Bye! 👋"
  exit 0
}
trap cleanup SIGINT SIGTERM

# ── Detect OS ─────────────────────────────────────────────────────────────────
case "$(uname -s)" in
  Darwin)           OS="mac"     ;;
  Linux)            OS="linux"   ;;
  MINGW*|MSYS*|CYGWIN*) OS="win-bash" ;;  # Git Bash / MSYS2 on Windows
  *)  err "Unsupported OS: $(uname -s)"; exit 1 ;;
esac

# ── Detect Docker Compose command (V2 plugin OR V1 standalone) ────────────────
detect_compose() {
  if docker compose version &>/dev/null 2>&1; then
    DC="docker compose"
  elif command -v docker-compose &>/dev/null; then
    DC="docker-compose"
  else
    DC=""
  fi
}

# ── Install helper (macOS & Linux only) ──────────────────────────────────────
install_pkg() {
  local name="$1" brew_pkg="${2:-$1}" apt_pkg="${3:-$1}"
  warn "$name not found — installing…"
  if [[ "$OS" == "mac" ]]; then
    command -v brew &>/dev/null || { err "Homebrew not found. Install: https://brew.sh"; exit 1; }
    brew install "$brew_pkg" --quiet
  elif [[ "$OS" == "linux" ]]; then
    if command -v apt-get &>/dev/null; then
      sudo apt-get update -qq && sudo apt-get install -y -qq "$apt_pkg"
    elif command -v yum &>/dev/null; then
      sudo yum install -y -q "$apt_pkg"
    elif command -v dnf &>/dev/null; then
      sudo dnf install -y -q "$apt_pkg"
    else
      err "Cannot auto-install $name. Please install it manually."; exit 1
    fi
  fi
}

# ── Cross-platform port killer ────────────────────────────────────────────────
kill_port() {
  local port="$1"; local pid=""
  if   command -v lsof   &>/dev/null; then pid=$(lsof -ti :"$port" 2>/dev/null || true)
  elif command -v fuser  &>/dev/null; then pid=$(fuser "$port"/tcp 2>/dev/null | tr -s ' ' '\n' | grep -v '^$' || true)
  elif command -v ss     &>/dev/null; then pid=$(ss -lptn "sport = :$port" 2>/dev/null | grep -oP 'pid=\K[0-9]+' || true)
  fi
  if [[ -n "${pid:-}" ]]; then
    warn "Port $port in use (PID $pid) — killing it…"
    echo "$pid" | xargs kill -9 2>/dev/null || true
    sleep 0.5
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}${BLUE}╔══════════════════════════════════════╗${RESET}"
echo "${BOLD}${BLUE}║     🏆  Scoreboard Pro — Dev Run     ║${RESET}"
echo "${BOLD}${BLUE}╚══════════════════════════════════════╝${RESET}"
echo ""

# ── --stop ────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--stop" ]]; then
  detect_compose
  pkill -f "go run ./cmd/server" 2>/dev/null && ok "Backend killed"  || warn "Backend wasn't running"
  pkill -f "vite"                2>/dev/null && ok "Frontend killed" || warn "Frontend wasn't running"
  [[ -n "${DC:-}" ]] && $DC -f "$ROOT/docker-compose.yml" stop postgres 2>/dev/null && ok "Postgres stopped" || true
  exit 0
fi

step "Checking prerequisites"

# ── 1. Docker ─────────────────────────────────────────────────────────────────
if ! command -v docker &>/dev/null; then
  case "$OS" in
    mac)      err "Install Docker Desktop: https://www.docker.com/products/docker-desktop/"; exit 1 ;;
    win-bash) err "Install Docker Desktop for Windows: https://www.docker.com/products/docker-desktop/"; exit 1 ;;
    linux)    install_pkg "Docker" "docker" "docker.io"
              sudo systemctl enable --now docker 2>/dev/null || true ;;
  esac
fi
ok "Docker: $(docker --version | head -1)"

if ! docker info &>/dev/null; then
  if [[ "$OS" == "mac" ]]; then
    warn "Docker not running — starting Docker Desktop…"
    open -a Docker 2>/dev/null || true
    RETRIES=60
    until docker info &>/dev/null; do
      sleep 1; RETRIES=$((RETRIES-1))
      [[ $RETRIES -le 0 ]] && { err "Docker didn't start. Open Docker Desktop manually."; exit 1; }
    done
  elif [[ "$OS" == "win-bash" ]]; then
    warn "Docker not running. Start Docker Desktop for Windows, then re-run this script."
    exit 1
  else
    sudo systemctl start docker 2>/dev/null || { err "Cannot start Docker. Run: sudo systemctl start docker"; exit 1; }
    sleep 2
  fi
fi
ok "Docker is running"

# ── 2. Docker Compose ─────────────────────────────────────────────────────────
detect_compose
if [[ -z "${DC:-}" ]]; then
  warn "Docker Compose not found — installing…"
  if [[ "$OS" == "linux" ]]; then
    sudo apt-get install -y -qq docker-compose-plugin 2>/dev/null || \
    sudo apt-get install -y -qq docker-compose 2>/dev/null || {
      ARCH="$(uname -m)"; [[ "$ARCH" == "aarch64" ]] && ARCH="aarch64" || ARCH="x86_64"
      sudo mkdir -p /usr/local/lib/docker/cli-plugins
      sudo curl -fsSL "https://github.com/docker/compose/releases/download/v2.24.5/docker-compose-linux-${ARCH}" \
        -o /usr/local/lib/docker/cli-plugins/docker-compose
      sudo chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
    }
    detect_compose
  fi
fi
[[ -z "${DC:-}" ]] && { err "Docker Compose required. See: https://docs.docker.com/compose/install/"; exit 1; }
ok "Docker Compose: $($DC version --short 2>/dev/null || $DC version 2>/dev/null | head -1)"

# ── --prod ────────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--prod" ]]; then
  step "Production Mode (full docker stack)"
  cd "$ROOT" && $DC up --build -d
  echo ""
  echo "${BOLD}${GREEN}╔═════════════════════════════════════╗${RESET}"
  echo "${BOLD}${GREEN}║  ✅  Production stack is running!   ║${RESET}"
  echo "${BOLD}${GREEN}╠═════════════════════════════════════╣${RESET}"
  echo "${BOLD}${GREEN}║  App  →  http://localhost           ║${RESET}"
  echo "${BOLD}${GREEN}║  Login: admin@scoreboard.local      ║${RESET}"
  echo "${BOLD}${GREEN}║  Pass:  Admin@1234                  ║${RESET}"
  echo "${BOLD}${GREEN}╠═════════════════════════════════════╣${RESET}"
  echo "${BOLD}${GREEN}║  Stop: $DC down            ║${RESET}"
  echo "${BOLD}${GREEN}╚═════════════════════════════════════╝${RESET}"
  exit 0
fi

# ── 3. Go ─────────────────────────────────────────────────────────────────────
if ! command -v go &>/dev/null; then
  case "$OS" in
    mac) install_pkg "Go" "go"; export PATH="$PATH:$(brew --prefix go 2>/dev/null)/bin" ;;
    win-bash) err "Go not found. Download and install: https://go.dev/dl/"; exit 1 ;;
    linux)
      GOARCH="amd64"; [[ "$(uname -m)" == "aarch64" ]] && GOARCH="arm64"
      warn "Go not found — downloading Go 1.22 (${GOARCH})…"
      curl -fsSL "https://go.dev/dl/go1.22.4.linux-${GOARCH}.tar.gz" -o /tmp/go.tar.gz
      sudo rm -rf /usr/local/go && sudo tar -C /usr/local -xzf /tmp/go.tar.gz && rm /tmp/go.tar.gz
      export PATH="$PATH:/usr/local/go/bin"
      grep -q '/usr/local/go/bin' ~/.bashrc 2>/dev/null || echo 'export PATH=$PATH:/usr/local/go/bin' >> ~/.bashrc
      ;;
  esac
fi
export PATH="$PATH:/usr/local/go/bin"
command -v go &>/dev/null || { err "Go not found. Download: https://go.dev/dl/"; exit 1; }
ok "Go: $(go version)"

# ── 4. Node.js ────────────────────────────────────────────────────────────────
if ! command -v node &>/dev/null; then
  case "$OS" in
    mac) install_pkg "Node.js" "node" ;;
    win-bash) err "Node.js not found. Download: https://nodejs.org/"; exit 1 ;;
    linux)
      warn "Node.js not found — installing Node 20 via NodeSource…"
      curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - &>/dev/null
      sudo apt-get install -y -qq nodejs
      ;;
  esac
fi
ok "Node.js: $(node --version)"

# ── 5. .env setup ─────────────────────────────────────────────────────────────
if [[ ! -f "$BACKEND/.env" ]]; then
  warn "backend/.env missing — copying from .env.example"
  cp "$ROOT/.env.example" "$BACKEND/.env"
  ok "Created backend/.env"
fi

# ── 6. Postgres ───────────────────────────────────────────────────────────────
step "Starting Postgres (Docker)"
cd "$ROOT"
$DC up postgres -d 2>/dev/null || $DC up postgres --detach 2>/dev/null || true

log "Waiting for Postgres to be healthy…"
RETRIES=40
until $DC exec -T postgres pg_isready -U scoreboard -d scoreboard -q 2>/dev/null; do
  RETRIES=$((RETRIES-1))
  [[ $RETRIES -le 0 ]] && { err "Postgres failed. Run: $DC logs postgres"; exit 1; }
  sleep 1
done
ok "Postgres is ready"

# ── 7. Backend ────────────────────────────────────────────────────────────────
kill_port 8080
step "Starting Backend (Go)"
cd "$BACKEND"
(go run ./cmd/server 2>&1 | while IFS= read -r line; do echo "${BOLD}${MAGENTA}[backend]${RESET} $line"; done) &
BACKEND_PID=$!

log "Waiting for backend on :8080…"
RETRIES=30
until curl -sf http://localhost:8080/health &>/dev/null; do
  RETRIES=$((RETRIES-1))
  [[ $RETRIES -le 0 ]] && { err "Backend didn't start."; cleanup; exit 1; }
  sleep 0.5
done
ok "Backend ready → http://localhost:8080"

# ── 8. Frontend ───────────────────────────────────────────────────────────────
step "Starting Frontend (Vite / React)"
cd "$FRONTEND"
if [[ ! -d node_modules ]]; then
  warn "node_modules missing — running npm install…"
  npm install --legacy-peer-deps --silent && ok "npm install done"
fi
(npm run dev -- --host 0.0.0.0 2>&1 | while IFS= read -r line; do echo "${BOLD}${YELLOW}[frontend]${RESET} $line"; done) &
FRONTEND_PID=$!

log "Waiting for frontend on :3000…"
RETRIES=40
until curl -sf http://localhost:3000 &>/dev/null; do
  RETRIES=$((RETRIES-1))
  [[ $RETRIES -le 0 ]] && { err "Frontend didn't start."; cleanup; exit 1; }
  sleep 0.5
done

# ── Ready ─────────────────────────────────────────────────────────────────────
echo ""
echo "${BOLD}${GREEN}╔════════════════════════════════════════════════════╗${RESET}"
echo "${BOLD}${GREEN}║          ✅  Everything is running!                ║${RESET}"
echo "${BOLD}${GREEN}╠════════════════════════════════════════════════════╣${RESET}"
echo "${BOLD}${GREEN}║  🖥  Admin Dashboard  → http://localhost:3000      ║${RESET}"
echo "${BOLD}${GREEN}║  📺  Display Screen   → http://localhost:3000/display ║${RESET}"
echo "${BOLD}${GREEN}║  📱  Scorer Connect   → http://localhost:3000/connect ║${RESET}"
echo "${BOLD}${GREEN}║  ⚙️   Backend API      → http://localhost:8080/api  ║${RESET}"
echo "${BOLD}${GREEN}╠════════════════════════════════════════════════════╣${RESET}"
echo "${BOLD}${GREEN}║  Default login:  admin@scoreboard.local            ║${RESET}"
echo "${BOLD}${GREEN}║  Password:       Admin@1234                        ║${RESET}"
echo "${BOLD}${GREEN}╠════════════════════════════════════════════════════╣${RESET}"
echo "${BOLD}${GREEN}║  Press  Ctrl+C  to stop everything                 ║${RESET}"
echo "${BOLD}${GREEN}╚════════════════════════════════════════════════════╝${RESET}"
echo ""

wait $BACKEND_PID $FRONTEND_PID
