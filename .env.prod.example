# Copy to ".env" on the server (next to docker-compose.prod.yml) and fill in.
#   cp .env.prod.example .env && nano .env

# Your domain (A record must point to the server's public IP).
DOMAIN=scorecast.simpedu.in

# Public URL — used for the QR / connect / display links shown in the dashboard.
PUBLIC_BASE_URL=https://scorecast.simpedu.in

# Long random secret for signing login tokens (generate: openssl rand -hex 32).
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Database password (any strong value; only used internally).
DB_PASSWORD=CHANGE_ME_strong_db_password
