# ── Server ──────────────────────────────────────────────────────────────
SERVER_PORT=8080
ENVIRONMENT=development   # development | production

# ── Database ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=scoreboard
DB_PASSWORD=scoreboard_secret
DB_NAME=scoreboard
DB_SSLMODE=disable
# Or use a full DSN:
# DATABASE_URL=postgres://scoreboard:scoreboard_secret@localhost:5432/scoreboard?sslmode=disable

# ── Auth ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this in production — minimum 32 characters
JWT_SECRET=change_this_secret_in_production_min_32_chars

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=*   # use your domain in production, e.g.: https://score.example.com

# ── Docker / Networking ──────────────────────────────────────────────────
HTTP_PORT=80
